{
  "entities": {
    "Assessment": {
      "title": "Assessment",
      "description": "A field assessment record for occupational hygiene.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["chemical", "noise"] },
        "status": { "type": "string", "enum": ["open", "completed"] },
        "createdAt": { "type": "number" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "workerName": { "type": "string" },
        "company": { "type": "string" },
        "sector": { "type": "string" },
        "role": { "type": "string" },
        "equipmentNumber": { "type": "string" },
        "equipmentModel": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "signature": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "type", "status", "createdAt", "workerName", "userId"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Collection of all assessments."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
